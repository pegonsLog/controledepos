{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli@20", "mcp"],
      "disabled": true
    },
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "experimental:mcp",
        "--dir",
        "c:/projetos/controledepos/controlepos",
        "--only",
        "auth,firestore,dataconnect"
      ],
      "disabled": false
    }
  }
}
